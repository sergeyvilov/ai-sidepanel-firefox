{
  "manifest_version": 3,
  "name": "AI Sidebar",
  "version": "2.0",
  "description": "Select text anywhere and explain it with ChatGPT, Gemini, Claude, or Mistral in a sidebar",
  "permissions": [
    "contextMenus",
    "activeTab",
    "tabs",
    "storage",
    "sidePanel",
    "scripting",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "*://chatgpt.com/*",
    "*://chat.openai.com/*",
    "*://gemini.google.com/*",
    "*://claude.ai/*",
    "*://chat.mistral.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "AI Sidebar"
  },
  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://chatgpt.com/*",
        "*://chat.openai.com/*",
        "*://gemini.google.com/*",
        "*://claude.ai/*",
        "*://chat.mistral.ai/*"
      ],
      "js": ["compat.js", "providers.js", "inject.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "strip_headers",
        "enabled": true,
        "path": "chrome_rules.json"
      }
    ]
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "64": "icons/icon-64.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "commands": {
    "prompt-1": {
      "suggested_key": {
        "default": "Alt+Shift+1",
        "mac": "MacCtrl+Shift+1"
      },
      "description": "Run Prompt 1"
    },
    "prompt-2": {
      "suggested_key": {
        "default": "Alt+Shift+2",
        "mac": "MacCtrl+Shift+2"
      },
      "description": "Run Prompt 2"
    },
    "prompt-3": {
      "suggested_key": {
        "default": "Alt+Shift+3",
        "mac": "MacCtrl+Shift+3"
      },
      "description": "Run Prompt 3"
    },
    "prompt-4": {
      "suggested_key": {
        "default": "Alt+Shift+4",
        "mac": "MacCtrl+Shift+4"
      },
      "description": "Run Prompt 4"
    }
  }
}
